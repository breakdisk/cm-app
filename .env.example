# ============================================================
# LogisticOS — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your local values.
# NEVER commit .env to version control.
#
#   cp .env.example .env
#
# All secrets in production are managed via HashiCorp Vault.
# This file is for local development only.
# ============================================================

# ── Application Environment ──────────────────────────────────
APP_ENV=development
APP_NAME=LogisticOS
APP_VERSION=0.1.0
LOG_LEVEL=debug
RUST_LOG=debug,sqlx=warn,hyper=warn

# ============================================================
# DATABASE — PostgreSQL (PostGIS)
# ============================================================
DATABASE_URL=postgres://logisticos:password@localhost:5432/logisticos
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=logisticos
POSTGRES_PASSWORD=password
POSTGRES_DB=logisticos

# Connection pool settings
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=2
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_IDLE_TIMEOUT_SECONDS=600

# Read replica (optional — leave blank for dev)
DATABASE_READ_REPLICA_URL=

# ============================================================
# REDIS — Cache, sessions, pub/sub, rate limiting
# ============================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20
REDIS_CONNECT_TIMEOUT_MS=3000

# Session TTL
REDIS_SESSION_TTL_SECONDS=86400
REDIS_RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================
# KAFKA — Event streaming
# ============================================================
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=logisticos-dev
KAFKA_CLIENT_ID=logisticos-local
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_ENABLE_AUTO_COMMIT=false
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_MAX_POLL_INTERVAL_MS=300000
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_TOPIC_PARTITIONS=3

# ============================================================
# AUTH / JWT / SECURITY
# ============================================================
# IMPORTANT: Generate a strong random secret for production:
#   openssl rand -base64 64
JWT_SECRET=dev-jwt-secret-CHANGE-IN-PRODUCTION-minimum-32-chars
JWT_EXPIRY_SECONDS=3600
REFRESH_TOKEN_EXPIRY_DAYS=7
JWT_ALGORITHM=HS256
JWT_ISSUER=logisticos.io

# OIDC / OAuth2 (for SSO integration)
OAUTH_CLIENT_ID=logisticos-local-client
OAUTH_CLIENT_SECRET=local-client-secret
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback
OAUTH_SCOPES=openid profile email

# API key settings
API_KEY_PREFIX=mk_live_
API_KEY_HASH_ROUNDS=12

# CORS (comma-separated allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ============================================================
# SERVICE PORTS
# ============================================================
API_GATEWAY_PORT=8000
IDENTITY_PORT=8001
CDP_PORT=8002
ENGAGEMENT_PORT=8003
ORDER_INTAKE_PORT=8004
DISPATCH_PORT=8005
DRIVER_OPS_PORT=8006
DELIVERY_EXPERIENCE_PORT=8007
FLEET_PORT=8008
HUB_OPS_PORT=8009
CARRIER_PORT=8010
POD_PORT=8011
PAYMENTS_PORT=8012
ANALYTICS_PORT=8013
MARKETING_PORT=8014
BUSINESS_LOGIC_PORT=8015
AI_LAYER_PORT=8016

# Internal gRPC ports (HTTP/2)
IDENTITY_GRPC_PORT=9001
DISPATCH_GRPC_PORT=9005
DRIVER_OPS_GRPC_PORT=9006

# Internal service base URLs (used for inter-service HTTP calls)
IDENTITY_SERVICE_URL=http://localhost:8001
IDENTITY_SERVICE_GRPC=localhost:9001
CDP_SERVICE_URL=http://localhost:8002
ENGAGEMENT_SERVICE_URL=http://localhost:8003
ORDER_INTAKE_SERVICE_URL=http://localhost:8004
DISPATCH_SERVICE_URL=http://localhost:8005
DRIVER_OPS_SERVICE_URL=http://localhost:8006
DELIVERY_EXPERIENCE_SERVICE_URL=http://localhost:8007
FLEET_SERVICE_URL=http://localhost:8008
HUB_OPS_SERVICE_URL=http://localhost:8009
CARRIER_SERVICE_URL=http://localhost:8010
POD_SERVICE_URL=http://localhost:8011
PAYMENTS_SERVICE_URL=http://localhost:8012
ANALYTICS_SERVICE_URL=http://localhost:8013
MARKETING_SERVICE_URL=http://localhost:8014
BUSINESS_LOGIC_SERVICE_URL=http://localhost:8015
AI_LAYER_SERVICE_URL=http://localhost:8016

# ============================================================
# AI / ML CONFIGURATION
# ============================================================
# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.3
CLAUDE_TIMEOUT_SECONDS=30

# OpenAI (embeddings + intent detection)
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# ONNX Model serving
ONNX_MODEL_PATH=/opt/logisticos/models
ONNX_THREAD_COUNT=4

# AI feature behaviour thresholds
AI_DISPATCH_CONFIDENCE_THRESHOLD=0.85
AI_CHURN_PREDICTION_WINDOW_DAYS=30
AI_DELAY_PREDICTION_LOOKAHEAD_HOURS=24

# ============================================================
# MCP (Model Context Protocol) SERVICE URLS
# ============================================================
# All AI agents interact with services exclusively through MCP
MCP_DISPATCH_URL=http://localhost:8005/mcp
MCP_ORDER_INTAKE_URL=http://localhost:8004/mcp
MCP_DRIVER_OPS_URL=http://localhost:8006/mcp
MCP_ENGAGEMENT_URL=http://localhost:8003/mcp
MCP_CDP_URL=http://localhost:8002/mcp
MCP_PAYMENTS_URL=http://localhost:8012/mcp
MCP_ANALYTICS_URL=http://localhost:8013/mcp
MCP_HUB_OPS_URL=http://localhost:8009/mcp
MCP_FLEET_URL=http://localhost:8008/mcp
MCP_CARRIER_URL=http://localhost:8010/mcp
MCP_POD_URL=http://localhost:8011/mcp
MCP_MARKETING_URL=http://localhost:8014/mcp
MCP_BUSINESS_LOGIC_URL=http://localhost:8015/mcp

# MCP server settings
MCP_SERVER_TIMEOUT_SECONDS=10
MCP_MAX_TOOL_RETRIES=3

# ============================================================
# EXTERNAL SERVICE INTEGRATIONS
# ============================================================

# ── Maps & Routing ──────────────────────────────────────────
MAPBOX_TOKEN=pk.REPLACE_WITH_YOUR_MAPBOX_TOKEN
MAPBOX_STYLE_DARK=mapbox://styles/mapbox/dark-v11
GOOGLE_MAPS_API_KEY=REPLACE_WITH_YOUR_GOOGLE_MAPS_KEY
HERE_API_KEY=REPLACE_WITH_YOUR_HERE_KEY

# ── Telephony / Messaging (Twilio) ───────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# WhatsApp Business API (Meta direct)
WHATSAPP_BUSINESS_ACCOUNT_ID=REPLACE_WITH_WABA_ID
WHATSAPP_ACCESS_TOKEN=REPLACE_WITH_ACCESS_TOKEN
WHATSAPP_PHONE_NUMBER_ID=REPLACE_WITH_PHONE_NUMBER_ID
WHATSAPP_WEBHOOK_VERIFY_TOKEN=local-webhook-verify-token

# SMS fallback
SMS_PROVIDER=twilio
SMS_SENDER_ID=LogisticOS

# ── Payments ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET
STRIPE_CURRENCY=php

PAYMONGO_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_PAYMONGO_KEY
PAYMONGO_PUBLIC_KEY=pk_test_REPLACE_WITH_YOUR_PAYMONGO_KEY

# COD reconciliation
COD_SETTLEMENT_DAY=WEDNESDAY
COD_FLOAT_MAX_DAYS=3

# ── Email ─────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@logisticos.io
SMTP_FROM_NAME=LogisticOS
SMTP_TLS=false

# Production email provider (SendGrid)
SENDGRID_API_KEY=SG.REPLACE_WITH_YOUR_SENDGRID_KEY

# ── Push Notifications ────────────────────────────────────────
FIREBASE_PROJECT_ID=logisticos-dev
FIREBASE_PRIVATE_KEY_PATH=/opt/logisticos/firebase-service-account.json
FCM_SERVER_KEY=REPLACE_WITH_YOUR_FCM_KEY

APNS_KEY_ID=REPLACE_WITH_APNS_KEY_ID
APNS_TEAM_ID=REPLACE_WITH_APNS_TEAM_ID
APNS_KEY_PATH=/opt/logisticos/apns-auth-key.p8
APNS_BUNDLE_ID=io.logisticos.customer

# ============================================================
# OBJECT STORAGE — S3 / MinIO
# ============================================================
S3_ENDPOINT=http://localhost:9001
S3_BUCKET=logisticos-dev
S3_BUCKET_POD=pod-evidence
S3_BUCKET_UPLOADS=merchant-uploads
S3_BUCKET_REPORTS=export-reports
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=ap-southeast-1
S3_FORCE_PATH_STYLE=true

# Production S3 (override for non-local envs):
# S3_ENDPOINT=https://s3.ap-southeast-1.amazonaws.com
# S3_FORCE_PATH_STYLE=false

# Signed URL expiry
S3_PRESIGNED_URL_EXPIRY_SECONDS=3600

# ============================================================
# CLICKHOUSE — Analytics warehouse
# ============================================================
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_TCP_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=logisticos
CLICKHOUSE_MAX_CONNECTIONS=10
CLICKHOUSE_CONNECT_TIMEOUT_SECONDS=5

# ============================================================
# TIMESCALEDB — Time-series (GPS, telemetry, metrics)
# ============================================================
# Uses the same PostgreSQL instance with TimescaleDB extension
TIMESCALE_URL=postgres://logisticos:password@localhost:5432/logisticos
TIMESCALE_RETENTION_DAYS=90

# ============================================================
# MONITORING & OBSERVABILITY
# ============================================================
# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_DAYS=30

# Grafana
GRAFANA_URL=http://localhost:3100
GRAFANA_PASSWORD=admin
GRAFANA_ADMIN_USER=admin

# OpenTelemetry / Jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=logisticos
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Loki (log aggregation)
LOKI_URL=http://localhost:3100

# Sentry (error tracking — leave blank for local dev)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================================
# FEATURE FLAGS
# ============================================================
ENABLE_AI_DISPATCH=true
ENABLE_MARKETING_AI=true
ENABLE_FRAUD_DETECTION=true
ENABLE_SMART_ROUTING=true
ENABLE_CHURN_PREDICTION=true
ENABLE_DYNAMIC_PRICING=false
ENABLE_BALIKBAYAN_WORKFLOW=true
ENABLE_CARRIER_AUTO_SELECTION=true
ENABLE_PREDICTIVE_ETA=true
ENABLE_CUSTOMER_SELF_RESCHEDULE=true
ENABLE_OTP_DELIVERY=false
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_WHATSAPP_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=true

# ============================================================
# MULTI-TENANCY
# ============================================================
DEFAULT_TENANT_REGION=ap-southeast-1
RLS_ENABLED=true
MAX_TENANTS_PER_SCHEMA=0

# ============================================================
# RATE LIMITING (requests per minute per API key)
# ============================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_RPM=1000
RATE_LIMIT_BURST_MULTIPLIER=2
RATE_LIMIT_WEBHOOK_RPM=100

# ============================================================
# GEOSPATIAL / ROUTING
# ============================================================
DEFAULT_TIMEZONE=Asia/Manila
DEFAULT_COUNTRY=PH
DEFAULT_CURRENCY=PHP
DISPATCH_MAX_DRIVER_RADIUS_KM=15
ROUTING_MAX_STOPS_PER_ROUTE=30
ROUTING_AVG_SPEED_URBAN_KMH=20
ROUTING_AVG_SPEED_PROVINCIAL_KMH=60

# ============================================================
# VAULT (HashiCorp) — Production secrets management
# ============================================================
# Leave blank for local dev (env vars used directly)
VAULT_ADDR=
VAULT_TOKEN=
VAULT_NAMESPACE=logisticos
VAULT_SECRET_PATH=secret/logisticos

# ============================================================
# KUBERNETES / DEPLOYMENT (CI/CD only — not needed locally)
# ============================================================
K8S_NAMESPACE=logisticos-production
HELM_RELEASE_PREFIX=logisticos
CONTAINER_REGISTRY=ghcr.io/logisticos

# ============================================================
# DEVELOPER TOOLS (local only)
# ============================================================
MAILHOG_HOST=localhost
MAILHOG_SMTP_PORT=1025
MAILHOG_HTTP_PORT=8025

PGADMIN_EMAIL=admin@logisticos.dev
PGADMIN_PASSWORD=admin

SWAGGER_UI_ENABLED=true
SWAGGER_UI_PATH=/docs

# ============================================================
# SECURITY NOTES
# ============================================================
# 1. Never commit .env with real values to git.
# 2. In production, all secrets are injected via Vault or
#    Kubernetes secrets — not environment files.
# 3. JWT_SECRET must be at least 32 characters of random data.
#    Generate with: openssl rand -base64 64
# 4. Database passwords must be rotated every 90 days.
# 5. Third-party API keys (Stripe, Anthropic, Twilio, etc.)
#    should be scoped to the minimum required permissions.
# 6. ANTHROPIC_API_KEY and OPENAI_API_KEY are masked in logs
#    at the application layer — never log full key values.
# 7. TWILIO_AUTH_TOKEN and STRIPE_SECRET_KEY trigger PCI-DSS
#    scope — ensure they never touch non-payment services.
