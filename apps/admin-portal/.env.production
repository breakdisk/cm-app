# Production environment for Admin Portal
# Update these values with your actual production domains before deploying

# API Services — all behind same domain (API Gateway handles routing)
# Change os-api.cargomarket.net to your actual production backend domain
NEXT_PUBLIC_IDENTITY_URL=https://os-api.cargomarket.net
NEXT_PUBLIC_ORDER_INTAKE_URL=https://os-api.cargomarket.net
NEXT_PUBLIC_DISPATCH_URL=https://os-api.cargomarket.net
NEXT_PUBLIC_DRIVER_OPS_URL=https://os-api.cargomarket.net
NEXT_PUBLIC_PAYMENTS_URL=https://os-api.cargomarket.net
NEXT_PUBLIC_ANALYTICS_URL=https://os-api.cargomarket.net
NEXT_PUBLIC_ENGAGEMENT_URL=https://os-api.cargomarket.net

# Main API Gateway / Base URL
NEXT_PUBLIC_API_URL=https://os-api.cargomarket.net
NEXT_PUBLIC_API_BASE=https://os-api.cargomarket.net

# Firebase Client (get from Firebase Console)
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=logisticos-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=logisticos-prod
NEXT_PUBLIC_FIREBASE_APP_ID=1:123:web:abc

# Landing app / Auth redirect
LANDING_URL=https://os.cargomarket.net
