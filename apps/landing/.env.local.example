# Firebase Client (public — safe to expose in browser)
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=logisticos-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=logisticos-prod
NEXT_PUBLIC_FIREBASE_APP_ID=1:123:web:abc

# Firebase Admin (server only — NEVER expose to browser)
# Generate: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Encode:   base64 -w 0 service-account.json   (Linux/Mac)
#           [Convert]::ToBase64String([IO.File]::ReadAllBytes('service-account.json'))  (PowerShell)
FIREBASE_SERVICE_ACCOUNT_JSON=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii4uLn0=

# Portal internal container URLs (server only — used by Next.js rewrites)
# In Dokploy, use the internal container name: http://<container-name>:<port>
MERCHANT_PORTAL_URL=http://localhost:3000
ADMIN_PORTAL_URL=http://localhost:3001
PARTNER_PORTAL_URL=http://localhost:3003
CUSTOMER_PORTAL_URL=http://localhost:3002

# Public API base (for the /track page)
NEXT_PUBLIC_API_URL=http://localhost:8007
