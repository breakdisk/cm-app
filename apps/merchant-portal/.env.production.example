# ── Production environment variables for merchant-portal ──────────────────
# Copy to .env.production (or set in Dokploy → App → Environment Variables)

# Public-facing API Gateway URL — must be reachable FROM THE BROWSER.
# This is typically the Traefik/nginx reverse-proxied address.
# Examples:
#   https://os-api.cargomarket.net
#   https://os.cargomarket.net:8000   (if port is exposed directly)
NEXT_PUBLIC_API_URL=https://os-api.cargomarket.net

# Firebase (if using Firebase auth bridge)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# LogisticOS internal secret (used by Next.js API routes, not browser)
LOGISTICOS_INTERNAL_SECRET=
