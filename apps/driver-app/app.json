{
  "expo": {
    "name": "LogisticOS Driver",
    "slug": "logisticos-driver",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "logisticos-driver",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#050810",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.logisticos.driver"
    },
    "android": {
      "package": "io.logisticos.driver"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        { "cameraPermission": "Allow LogisticOS Driver to access camera for barcode scanning and proof of delivery." }
      ],
      [
        "expo-location",
        { "locationAlwaysAndWhenInUsePermission": "Allow LogisticOS Driver to use your location for route tracking." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
